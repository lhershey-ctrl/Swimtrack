rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Owners: permanent admins, hardcoded. Can always access everything,
    //    generate invite codes, and manage coach accounts. Add more owner
    //    emails here only. ──
    function ownerEmails() {
      return [
        "lhershey@gmail.com"
      ];
    }

    function isOwner() {
      return request.auth != null
        && request.auth.token.email in ownerEmails();
    }

    // ── Legacy allow-list (config/access.emails) — pre-multi-coach shared
    //    family access. Kept only as (a) a bridge so lhershey/sharos88 keep
    //    working through the coachUids migration, and (b) a fallback so
    //    those two accounts can still read shared reference tables below.
    //    New coaches use coaches/{uid} instead — see isCoach(). ──
    function accessEmails() {
      return get(/databases/$(database)/documents/config/access).data.emails;
    }

    function isLegacyAllowed() {
      return request.auth != null
        && exists(/databases/$(database)/documents/config/access)
        && request.auth.token.email in accessEmails();
    }

    // ── Coaches: self-registered (via a one-time invite code redemption)
    //    after 2026-07. Existence of coaches/{uid} is what makes an account
    //    a coach — see the /coaches rules below for how a doc gets created. ──
    function isCoach() {
      return request.auth != null
        && exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }

    // Any recognized member of the app (owner, legacy family access, or a
    // registered coach) — used to gate reads of shared reference tables that
    // aren't per-coach data (Israeli records, Rudolph, USA standards, etc).
    function isMember() {
      return isOwner() || isCoach() || isLegacyAllowed();
    }

    match /coaches/{uid} {
      // Any registered coach can read any coach doc (needed to show a
      // teammate's team name when grouping shared swimmers into accounts —
      // see groupCoachesIntoTeams). Not a meaningful new exposure: co-coaches
      // can already see each other's emails via shared swimmers' coachEmails.
      allow read: if isOwner() || request.auth.uid == uid || isCoach();
      // Self-registration only: you may create your own doc (after redeeming
      // an invite code client-side) with your own email — you can never
      // create one for someone else.
      allow create: if request.auth != null && request.auth.uid == uid
        && request.resource.data.email == request.auth.token.email;
      // Only the owner can edit/remove a coach in general, EXCEPT a coach
      // may self-update just their own teamName (account/team display name,
      // set from Settings) — nothing else about another coach's doc.
      allow update: if isOwner()
        || (request.auth.uid == uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamName']));
      allow delete: if isOwner();
    }

    // A "team" is an explicit, nameable roster a coach creates under their
    // OWN login (see teamId on swimmers below) — distinct from the older,
    // purely-inferred coachUids-based grouping (which is how Team Har-Shai /
    // Team KFS work, and keeps working unchanged). Lets one email own more
    // than one independent, empty-to-start roster without a second Google
    // account. Read is any coach (needed to label a shared swimmer's team
    // for a viewer who didn't create it); only the creator may rename.
    match /teams/{teamId} {
      allow read: if isOwner() || isCoach();
      allow create: if request.auth != null && isCoach()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwner()
        || (isCoach() && resource.data.createdBy == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name']));
      allow delete: if isOwner();
    }

    match /inviteCodes/{code} {
      // Any signed-in user may fetch a SPECIFIC code (they already have to
      // know the exact string) to check validity before redeeming it — but
      // only the owner may LIST/enumerate every code that exists (admin
      // stats panel), so a random signed-in account can't discover and
      // race to redeem a code that wasn't given to them.
      allow get: if request.auth != null;
      allow list: if isOwner();
      // The owner can mint any kind of code (a brand-new independent coach,
      // or a "join my team" code on someone else's behalf, for support). A
      // regular coach can only mint a "join MY team" code (targetCoachUid
      // must be their own uid) — they can't grant access to anyone else's
      // roster.
      allow create: if request.auth != null && (
        isOwner()
        || (isCoach() && request.resource.data.targetCoachUid == request.auth.uid)
      );
      allow update: if request.auth != null
        && resource.data.usedBy == null
        && request.resource.data.usedBy == request.auth.token.email
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usedBy', 'usedAt']);
    }

    // A redeemer's self-written claim of "I redeemed a code that shares
    // these specific swimmer IDs with me" — written once, right after
    // redemption, using nothing but the redeemer's own auth (see
    // redeemInviteCode). The swimmers update rule below checks against this
    // instead of trying to verify an arbitrary invite code inline.
    match /pendingShares/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Swimmer data: isolated per coach via coachUids (an array, since a
    // swimmer can have more than one coach — e.g. the original two family
    // accounts sharing Noga/Gal). The owner can always read/write anything
    // (needed for the admin stats panel + support).
    match /swimmers/{swimmerId} {
      allow read, delete: if isOwner()
        || (isCoach() && 'coachUids' in resource.data && request.auth.uid in resource.data.coachUids);
      // Create doesn't need to inspect coachUids at all: a brand-new doc ID
      // has no prior owner to protect, so any coach may create one. If the
      // ID already belongs to someone, Firestore treats the write as an
      // UPDATE (not create) and the rule below — checked against the real
      // pre-write resource.data, not a client-supplied transform — applies
      // instead. (Deliberately avoids relying on arrayUnion() resolving
      // correctly inside request.resource.data, which is unreliable.)
      allow create: if isOwner() || isCoach();
      allow update: if isOwner()
        || (isCoach() && 'coachUids' in resource.data && request.auth.uid in resource.data.coachUids)
        // One-time bridge: a legacy allow-listed user (pre-multi-coach shared
        // family access) claims a swimmer they already had full access to,
        // by adding ONLY their own uid to coachUids — nothing else about the
        // document changes. Self-service; naturally stops mattering once
        // every legacy user has signed in once after this migration.
        || (
          isLegacyAllowed() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coachUids', 'coachEmails']) &&
          request.resource.data.coachUids ==
            (('coachUids' in resource.data) ? resource.data.coachUids : []).concat([request.auth.uid]) &&
          request.resource.data.coachEmails ==
            (('coachEmails' in resource.data) ? resource.data.coachEmails : []).concat([request.auth.token.email])
        )
        // Join-team bridge: the caller has a pendingShares/{their-uid} doc
        // (self-written right after redeeming a "join my team" invite code)
        // that explicitly lists THIS swimmer id, and the only change is
        // adding their own uid/email to coachUids/coachEmails — nothing else.
        || (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['coachUids', 'coachEmails']) &&
          request.resource.data.coachUids ==
            (('coachUids' in resource.data) ? resource.data.coachUids : []).concat([request.auth.uid]) &&
          request.resource.data.coachEmails ==
            (('coachEmails' in resource.data) ? resource.data.coachEmails : []).concat([request.auth.token.email]) &&
          exists(/databases/$(database)/documents/pendingShares/$(request.auth.uid)) &&
          swimmerId in get(/databases/$(database)/documents/pendingShares/$(request.auth.uid)).data.swimmerIds
        );
    }

    // The legacy access list: members can read it (needed for the migration
    // bridge check above); only owners can change it.
    match /config/access {
      allow read: if isMember();
      allow write: if isOwner();
    }

    // Israeli age records: every member can read; only owners can publish
    // (loaded ~once a year from the official record PDFs via the desktop app).
    match /config/records {
      allow read: if isMember();
      allow write: if isOwner();
    }

    // Rudolph age-graded points table: every member can read; only owners
    // can publish (loaded from the official Rudolph PDF via the desktop app).
    match /config/rudolph {
      allow read: if isMember();
      allow write: if isOwner();
    }

    // USA Swimming Motivational Standards (junior, SCM/LCM): every member
    // can read; only owners can publish (loaded via the desktop app).
    match /config/usaStandards {
      allow read: if isMember();
      allow write: if isOwner();
    }

    // World Aquatics Masters world records (SCM/LCM): every member can
    // read; only owners can publish (loaded via the desktop app).
    match /config/mastersRecords {
      allow read: if isMember();
      allow write: if isOwner();
    }
  }
}
